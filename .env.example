# ──────────────────────────────────────────────────────────────────────────
# SyncWave-Web environment
#
# With NO Supabase vars set, the app runs in LOCAL MODE: real-time sync works
# only between tabs of the SAME browser (via BroadcastChannel). Great for a
# quick demo; open two tabs and watch the Resonance Ring breathe in unison.
#
# Set the two Supabase vars below to enable CROSS-DEVICE sync (the real thing).
# ──────────────────────────────────────────────────────────────────────────

# Supabase project (Project Settings → API). Required for cross-device sync.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# OPTIONAL — enables in-app YouTube search (otherwise you can still paste a
# YouTube URL/ID directly). Get one from the Google Cloud console (YouTube
# Data API v3). Server-side only; never exposed to the client.
YOUTUBE_API_KEY=
